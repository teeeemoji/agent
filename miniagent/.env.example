# LLM API 配置示例
# 复制此文件为 .env 并填入你的真实配置

# API Key（必填）
OPENAI_API_KEY=sk-your-api-key-here

# 模型名称（必填）
# 示例：gpt-4o, gpt-4-turbo, deepseek-chat 等
OPENAI_MODEL=gpt-4o

# API 基础 URL（可选，默认为 OpenAI 官方地址）
# 使用其他兼容提供商时修改此项，例如：
# DeepSeek: https://api.deepseek.com/v1
# 本地模型: http://localhost:11434/v1
OPENAI_BASE_URL=https://api.openai.com/v1
